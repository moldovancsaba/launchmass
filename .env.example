# launchmass Environment Variables
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (it's in .gitignore)

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB connection string
# Get this from MongoDB Atlas or your MongoDB provider
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Database name (optional, defaults to 'launchmass')
DB_NAME=launchmass

# =============================================================================
# OAUTH 2.0 AUTHENTICATION (v1.7.0+)
# =============================================================================

# SSO Server URL
SSO_SERVER_URL=https://sso.doneisbetter.com

# OAuth Client Credentials (get these from SSO admin panel)
# CLIENT_SECRET is SENSITIVE - never expose to browser
SSO_CLIENT_ID=your-oauth-client-id-here
SSO_CLIENT_SECRET=your-oauth-client-secret-here

# OAuth Callback URI (must match SSO admin panel exactly)
SSO_REDIRECT_URI=https://launchmass.doneisbetter.com/api/oauth/callback

# Session signing secret — HMAC key for the sso_session cookie (server-side only, SENSITIVE).
# The sso_session cookie is signed and verified with this key (see lib/session.js).
# If unset, signing falls back to SSO_CLIENT_SECRET; set a DEDICATED random value in
# production so session integrity does not depend on the OAuth client secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=your-long-random-session-secret-here

# =============================================================================
# PUBLIC ENVIRONMENT VARIABLES (Client-Side Accessible)
# These are exposed to the browser via NEXT_PUBLIC_ prefix
# =============================================================================

# Public SSO Server URL (for client-side OAuth redirects)
NEXT_PUBLIC_SSO_SERVER_URL=https://sso.doneisbetter.com

# Public OAuth Client ID (safe to expose)
NEXT_PUBLIC_SSO_CLIENT_ID=your-oauth-client-id-here

# Public OAuth Callback URI (for client-side redirect construction)
NEXT_PUBLIC_SSO_REDIRECT_URI=https://launchmass.doneisbetter.com/api/oauth/callback

# =============================================================================
# APPLICATION CONFIGURATION (Optional)
# =============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# Base URL for seeding operations (optional)
BASE_URL=http://localhost:6500

# Auto-grant access to new users on first OAuth login (default: true)
# Set to 'false' to require admin approval for all new users
# When true: New users get immediate access with 'user' role
# When false: New users must be approved via /admin/users interface
AUTO_GRANT_ACCESS=true

# Debug flags (optional) — leave unset in production.
# OAUTH_DEBUG=true logs OAuth callback details (auth code, email, token presence).
# ORG_CACHE_DEBUG=true logs per-request organization-context resolution.
# OAUTH_DEBUG=false
# ORG_CACHE_DEBUG=false

# =============================================================================
# NOTES
# =============================================================================
#
# 1. NEVER commit .env.local to git - it's automatically ignored
#
# 2. Production Environment:
#    - Set all variables in Vercel Project Settings → Environment Variables
#    - Use production values for SSO_REDIRECT_URI
#    - Ensure SSO_CLIENT_SECRET and SESSION_SECRET are marked as sensitive in Vercel
#    - Set a dedicated SESSION_SECRET in production so session-cookie integrity does
#      not depend on the OAuth client secret
#
# 3. Development Environment:
#    - Copy this file to .env.local
#    - Use development/staging credentials if available
#    - Admin features require *.doneisbetter.com subdomain (NOT localhost)
#    - Public pages work fine on localhost
#
# 4. OAuth Configuration:
#    - Register OAuth client in SSO admin panel at sso.doneisbetter.com
#    - Redirect URI must match exactly: https://launchmass.doneisbetter.com/api/oauth/callback
#    - Request scopes: openid profile email offline_access
#
# 5. Database:
#    - Always use production MongoDB for local development (no separate dev DB)
#    - Reason: Ensures data parity and identical behavior
#    - Security: Keep MONGODB_URI in .env.local, never commit
#
# 6. Missing Variables:
#    - App will fail to start if required variables are missing
#    - Check console output for specific missing variable errors
#    - Refer to AUTH_CURRENT.md for complete authentication setup
#
# =============================================================================
# REFERENCE
# =============================================================================
#
# For complete documentation see:
# - AUTH_CURRENT.md - OAuth 2.0 authentication guide
# - ARCHITECTURE.md - System architecture and configuration
# - WARP.md - Development environment setup
# - README.md - Quick start guide
